{
    "name": "bar-lobby",
    "type": "module",
    "version": "0.15.3",
    "private": true,
    "description": "Lobby client for the RTS game Beyond All Reason",
    "author": "The BAR Lobby Authors",
    "license": "SEE LICENSE IN LICENSE.md",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/beyond-all-reason/bar-lobby.git"
    },
    "main": ".vite/build/main.cjs",
    "scripts": {
        "start": "cross-env NODE_OPTIONS=--enable-source-maps electron-forge start",
        "package": "electron-forge package",
        "preview": "electron-forge package && cross-env NODE_OPTIONS=--enable-source-maps NODE_ENV=production electron .",
        "build:win": "electron-builder --win",
        "buildall:win": "npm run package && npm run build:win",
        "build:linux": "electron-builder --linux",
        "buildall:linux": "npm run package && npm run build:linux",
        "build:unpack": "electron-builder --dir",
        "dev-cert": "electron-builder create-self-signed-cert -p \"BAR Team\"",
        "build:win:dev-cert": "cross-env CSC_LINK=\"./BAR Team.pfx\" npm run build:win",
        "postinstall": "electron-builder install-app-deps",
        "release": "electron-builder --publish always",
        "lint": "eslint --cache",
        "test": "vitest run tests",
        "pretest:e2e": "electron-forge package",
        "test:e2e": "cross-env playwright test",
        "format": "prettier --experimental-cli --write .",
        "format:check": "prettier --experimental-cli --check .",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "concurrently \"npm run typecheck:node\" \"npm run typecheck:web\"",
        "checks": "concurrently \"npm run typecheck:web\" \"npm run typecheck:node\" \"npm run lint\" \"npm run format:check\"",
        "generate-i18n-assets": "node --import=tsx tools/generate-i18n-asset-files.ts"
    },
    "engines": {
        "node": "22.18.0"
    },
    "dependencies": {
        "@extractus/feed-extractor": "^7.1.7",
        "@iconify-icons/mdi": "^1.2.48",
        "@iconify/json": "^2.2.466",
        "@iconify/vue": "^5.0.0",
        "@sinclair/typebox": "^0.34.49",
        "@vueuse/core": "^14.2.1",
        "7zip-bin": "^5.2.0",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "axios": "^1.15.2",
        "chokidar": "^5.0.0",
        "date-fns": "^4.1.0",
        "dexie": "^4.4.2",
        "dompurify": "^3.4.1",
        "flag-icons": "^7.5.0",
        "glob-promise": "^6.0.7",
        "howler": "^2.2.4",
        "json8-merge-patch": "^1.0.5",
        "luaparse": "^0.3.1",
        "marked": "^18.0.2",
        "node-abi": "^4.12.0",
        "node-downloader-helper": "^2.1.11",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "playwright": "^1.59.1",
        "primeicons": "^7.0.0",
        "primevue": "4.5.5",
        "@primeuix/utils": "0.7.1",
        "tachyon-protocol": "^1.20.0",
        "vue-i18n": "^11.4.0",
        "vue-router": "^5.0.6",
        "ws": "^8.20.0",
        "vue": "^3.5.33"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/plugin-vite": "^7.11.1",
        "@playwright/test": "^1.59.1",
        "@types/howler": "^2.2.12",
        "@types/luaparse": "^0.2.13",
        "@types/node": "^25.6.0",
        "@types/wait-on": "^5.3.4",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/test-utils": "^2.4.8",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "41.3.0",
        "electron-builder": "^26.8.1",
        "electron-updater": "^6.8.3",
        "eslint": "^10.2.1",
        "@eslint/js": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-vue": "^10.9.0",
        "globals": "^17.5.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.3",
        "sass": "^1.99.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10",
        "vite-plugin-static-copy": "^4.1.0",
        "vite-plugin-vue-devtools": "^8.1.1",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.7",
        "wait-on": "^9.0.5"
    }
}
